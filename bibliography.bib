	coden = {ITNNE},
	language = {English},
	abbrev_source_title = {IEEE Trans Neural Networks},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	
}



@ARTICLE{Digitalization-of-retailing-Hagberg,
